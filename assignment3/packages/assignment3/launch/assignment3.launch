<launch>
  <arg name="veh" default="$(optenv VEHICLE_NAME bear)"/>

  <node pkg="assignment3"
        type="navigator_node.py"
        name="assignment3_navigator"
        output="screen">

    <param name="robot_name"             value="$(arg veh)"/>
    <param name="cmd_topic"              value="/$(arg veh)/car_cmd_switch_node/cmd"/>

    <param name="linear_speed"           value="0.18"/>
    <param name="align_linear_speed"     value="0.0"/> 

    <param name="angular_gain"           value="2.0"/>
    <param name="max_angular_speed"      value="3.0"/> <param name="yaw_bias"               value="0.0"/>

    <param name="right_turn_omega_scale" value="2.2"/> <param name="search_right_scale"     value="2.2"/>
    <param name="min_turn_omega"         value="1.3"/> <param name="search_angular_speed"   value="2.2"/> <param name="search_linear_speed"    value="0.0"/> 

    <param name="align_angle_max"        value="0.25"/> <param name="proximity_threshold"    value="0.30"/>
    <param name="detection_stale_sec"    value="1.0"/>
    <param name="lost_coast_sec"         value="0.35"/>
    <param name="aruco_dictionary"       value="DICT_5X5_50"/>

  </node>
</launch>